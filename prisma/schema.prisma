generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TECHNICIAN
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(TECHNICIAN)
  reports   Report[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Hospital {
  id        Int      @id @default(autoincrement())
  name      String
  address   String?
  acUnits   AcUnit[]
  reports   Report[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hospitals")
}

model AcUnit {
  id         Int      @id @default(autoincrement())
  hospitalId Int
  name       String
  hospital   Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  reports    Report[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([hospitalId])
  @@unique([hospitalId, name])
  @@map("ac_units")
}

model Report {
  id         Int       @id @default(autoincrement())
  userId     Int
  hospitalId Int
  acUnitId   Int
  photoUrl   String
  note       String?   @db.Text
  latitude   Decimal?  @db.Decimal(10, 7)
  longitude  Decimal?  @db.Decimal(10, 7)
  createdAt  DateTime  @default(now())

  user       User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  hospital   Hospital  @relation(fields: [hospitalId], references: [id], onDelete: Restrict)
  acUnit     AcUnit    @relation(fields: [acUnitId], references: [id], onDelete: Restrict)

  @@index([createdAt])
  @@index([hospitalId, createdAt])
  @@index([userId, createdAt])
  @@index([acUnitId, createdAt])
  @@map("reports")
}
